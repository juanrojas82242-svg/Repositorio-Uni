        self.siguiente = None


class Conjunto:
    def __init__(self):
        self.cabeza = None

    def pertenece(self, x):
        """
        Retorna True si x está en el conjunto.
        """
        actual = self.cabeza
        while actual:
            if actual.dato == x:
                return True
            actual = actual.siguiente
        return False

    def agregar(self, x):
        """
        Agrega x al conjunto si no existe.
        """
        if self.pertenece(x):
            return
        nuevo = Nodo(x)
        nuevo.siguiente = self.cabeza
        self.cabeza = nuevo

    def __str__(self):
        elementos = []
        actual = self.cabeza
        while actual:
            elementos.append(str(actual.dato))
            actual = actual.siguiente
        return "{" + ", ".join(elementos) + "}"


