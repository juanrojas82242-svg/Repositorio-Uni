class Nodo:
    def __init__(self, dato):
        self.dato = dato
        self.siguiente = None


class Conjunto:
    def __init__(self):
        self.cabeza = None

    def pertenece(self, x):
        actual = self.cabeza
        while actual:
            if actual.dato == x:
                return True
            actual = actual.siguiente
        return False

    def agregar(self, x):
        if self.pertenece(x):
            return
        nuevo = Nodo(x)
        nuevo.siguiente = self.cabeza
        self.cabeza = nuevo

    def __str__(self):
        elementos = []
        actual = self.cabeza
        while actual:
            elementos.append(str(actual.dato))
            actual = actual.siguiente
        return "{" + ", ".join(elementos) + "}"


# ==============================
# FUNCIONES DE CONJUNTOS
# ==============================

def union(A, B):
    """
    Retorna un nuevo conjunto con elementos de A y B.
    """
    nuevo = Conjunto()

    actual = A.cabeza
    while actual:
        nuevo.agregar(actual.dato)
        actual = actual.siguiente

    actual = B.cabeza
    while actual:
        nuevo.agregar(actual.dato)
        actual = actual.siguiente

    return nuevo


def interseccion(A, B):
    """
    Elementos comunes entre A y B.
    """
    nuevo = Conjunto()

    actual = A.cabeza
    while actual:
        if B.pertenece(actual.dato):
            nuevo.agregar(actual.dato)
        actual = actual.siguiente

    return nuevo


def diferencia(A, B):
    """
    Elementos de A que no están en B.
    """
    nuevo = Conjunto()

    actual = A.cabeza
    while actual:
        if not B.pertenece(actual.dato):
            nuevo.agregar(actual.dato)
        actual = actual.siguiente

    return nuevo


def diferencia_simetrica(A, B):
    """
    Elementos que están en A o B pero no en ambos.
    """
    return union(diferencia(A, B), diferencia(B, A))


def tiene_algun_permiso(usuario, permisos):
    """
    Retorna True si el usuario tiene al menos uno de los permisos.
    """
    actual = permisos.cabeza
    while actual:
        if usuario.pertenece(actual.dato):
            return True
        actual = actual.siguiente
    return False


# ==============================
# BONUS
