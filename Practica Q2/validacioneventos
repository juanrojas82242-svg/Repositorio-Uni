def son_iguales(A, B):
    """
    Verifica si dos conjuntos son iguales.
    """
    actual = A.cabeza
    while actual:
        if not B.pertenece(actual.dato):
            return False
        actual = actual.siguiente

    actual = B.cabeza
    while actual:
        if not A.pertenece(actual.dato):
            return False
        actual = actual.siguiente

    return True


