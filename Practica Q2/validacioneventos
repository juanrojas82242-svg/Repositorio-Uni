]


# ==============================
# PARTE 1: MATRICES + SETS
# ==============================

def validar_persona(matriz, fila):
    """
    Verifica si una fila contiene exactamente los valores 1-9 sin repetir.
    """
    return set(matriz[fila]) == EVENTOS_VALIDOS


def validar_evento(matriz, columna):
    """
    Verifica si una columna contiene exactamente los valores 1-9.
    """
    valores = set()
    for i in range(9):
        valores.add(matriz[i][columna])
    return valores == EVENTOS_VALIDOS


def validar_zona(matriz, fila_inicio, col_inicio):
    """
    Verifica si un subcuadro 3x3 contiene los valores 1-9.
    """
    valores = set()
    for i in range(3):
        for j in range(3):
            valores.add(matriz[fila_inicio + i][col_inicio + j])
    return valores == EVENTOS_VALIDOS


def sistema_valido(matriz):
    """
    Verifica todo el sistema:
    - filas
    - columnas
    - zonas 3x3
    """
    # Validar filas
    for i in range(9):
        if not validar_persona(matriz, i):
            return False

    # Validar columnas
    for j in range(9):
        if not validar_evento(matriz, j):
            return False

    # Validar zonas
    for fi in [0,3,6]:
        for ci in [0,3,6]:
            if not validar_zona(matriz, fi, ci):
                return False

    return True


