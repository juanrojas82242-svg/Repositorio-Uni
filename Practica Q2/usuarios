# ==============================
# PARTE 1: STRINGS + SETS
# ==============================

USUARIOS = {
    "juan": ["python", "ia", "datos", "python"],
    "ana": ["ia", "ml", "datos"],
    "luis": ["web", "javascript", "css"],
    "maria": ["python", "ml", "ia"]
}


def intereses_unicos(usuario):
    """
    Retorna los intereses únicos de un usuario.

    Idea:
    - Convertir la lista a set elimina duplicados automáticamente
    """
    return set(USUARIOS[usuario])


def intereses_comunes(user1, user2):
    """
    Retorna los intereses en común entre dos usuarios.

    Idea:
    - Convertir ambos a set
    - Usar intersección (&)
    """
    set1 = set(USUARIOS[user1])
    set2 = set(USUARIOS[user2])
    return set1 & set2


def recomendar_intereses(user1, user2):
    """
    Retorna intereses que tiene user2 pero no user1.

    Idea:
    - Diferencia de conjuntos
    """
    set1 = set(USUARIOS[user1])
    set2 = set(USUARIOS[user2])
    return set2 - set1


# ==============================
# PARTE 2: LISTAS ENLAZADAS
# ==============================

class Nodo:
    """
    Nodo de la lista enlazada.
    """
    def __init__(self, dato):
        self.dato = dato
        self.siguiente = None


class Conjunto:
    """
    Implementación de conjunto usando lista enlazada.
    No permite duplicados.
    """
    def __init__(self):
        self.cabeza = None

    def pertenece(self, x):
        """
        Verifica si x está en el conjunto.
        """
        actual = self.cabeza
        while actual:
            if actual.dato == x:
                return True
            actual = actual.siguiente
        return False

    def agregar(self, x):
        """
        Agrega x si no existe.
        """
        if self.pertenece(x):
            return
        nuevo = Nodo(x)
        nuevo.siguiente = self.cabeza
        self.cabeza = nuevo

    def __str__(self):
        elementos = []
        actual = self.cabeza
        while actual:
            elementos.append(actual.dato)
            actual = actual.siguiente
        return str(elementos)


# ==============================
# FUNCIONES SOBRE CONJUNTOS
# ==============================

def lista_a_conjunto(lista_strings):
    """
    Convierte una lista de strings en un conjunto enlazado.

    Idea:
    - Recorrer lista
    - Agregar cada elemento (sin duplicados)
    """
    conjunto = Conjunto()

    for elemento in lista_strings:
        conjunto.agregar(elemento)

    return conjunto


def interseccion(A, B):
    """
    Retorna elementos comunes entre A y B.

    Idea:
    - Recorrer A
    - Si está en B → agregar
    """
    nuevo = Conjunto()

    actual = A.cabeza
    while actual:
        if B.pertenece(actual.dato):
            nuevo.agregar(actual.dato)
        actual = actual.siguiente

    return nuevo


def tiene_todos(usuario, requeridos):
    """
    Retorna True si usuario tiene TODOS los permisos.

    Idea:
    - Recorrer requeridos
    - Si falta uno → False
    """
    actual = requeridos.cabeza

    while actual:
        if not usuario.pertenece(actual.dato):
            return False
        actual = actual.siguiente

    return True


def tiene_alguno(usuario, requeridos):
    """
    Retorna True si usuario tiene AL MENOS uno.

    Idea:
    - Recorrer requeridos
    - Si encuentra uno → True
    """
    actual = requeridos.cabeza

    while actual:
        if usuario.pertenece(actual.dato):
            return True
        actual = actual.siguiente

    return False


# ==============================
# BONUS
# ==============================

def sugerir_amigos(user1, user2):
    """
    Sugiere amistad si tienen al menos 2 intereses en común.

    Idea:
    - Calcular intersección
    - Verificar tamaño
    """
    comunes = intereses_comunes(user1, user2)
    return len(comunes) >= 2


