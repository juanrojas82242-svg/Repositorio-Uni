    print("Intereses comunes Juan-Ana:", intereses_comunes("juan", "ana"))
    print("Recomendaciones para Juan desde Ana:", recomendar_intereses("juan", "ana"))

    # Convertir listas a conjuntos enlazados
    A = lista_a_conjunto(USUARIOS["juan"])
    B = lista_a_conjunto(USUARIOS["ana"])

    print("\nConjunto A:", A)
    print("Conjunto B:", B)

    print("Intersección:", interseccion(A, B))

    print("Tiene todos:", tiene_todos(A, B))
    print("Tiene alguno:", tiene_alguno(A, B))

    print("\n¿Sugerir amistad Juan-Ana?:", sugerir_amigos("juan", "ana"))






