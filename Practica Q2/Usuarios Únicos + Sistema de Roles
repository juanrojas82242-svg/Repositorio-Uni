                PARTE 1: USUARIOS ÚNICOS
═══════════════════════════════════════════════════════════════════════════════

Usar conjuntos de Python para validar listas de usuarios.

REGLAS:
- No debe haber usuarios repetidos
- Validar si dos grupos tienen usuarios en común
- Obtener la unión de todos los usuarios
"""

grupo_a = ["ana","juan","maria","carlos"]
grupo_b = ["sofia","juan","pedro","carlos"]

# PUNTO 1.1: Validar unicidad en un grupo
def validar_unicidad(grupo):
    """
    Retorna True si no hay usuarios repetidos
    """
    return len(set(grupo)) == len(grupo)

# PUNTO 1.2: Validar si dos grupos tienen usuarios en común
def tienen_comun(grupo1, grupo2):
    """
    Retorna True si hay al menos un usuario en común
    """
    return not set(grupo1).isdisjoint(set(grupo2))

# PUNTO 1.3: Obtener la unión de todos los usuarios
def union_usuarios(grupo1, grupo2):
    """
    Retorna un conjunto con todos los usuarios de ambos grupos
    """
    return set(grupo1) | set(grupo2)


