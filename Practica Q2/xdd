# ==============================
# DEFINICIÓN DE ESTRUCTURAS
# ==============================

class Nodo:
    """
    Representa un nodo de la lista enlazada.
    Cada nodo tiene:
    - valor: el dato almacenado
    - siguiente: referencia al siguiente nodo
    """
    def __init__(self, valor):
        self.valor = valor
        self.siguiente = None


class Lista:
    """
    Implementación de una lista enlazada simple.
    """
    def __init__(self):
        self.head = None

    def insertar_final(self, valor):
        """
        Inserta un nodo al final de la lista.
        """
        nuevo = Nodo(valor)

        # Si la lista está vacía
        if not self.head:
            self.head = nuevo
            return

        # Recorrer hasta el último nodo
        actual = self.head
        while actual.siguiente:
            actual = actual.siguiente

        actual.siguiente = nuevo

    def imprimir(self):
        """
        Imprime la lista enlazada.
        """
        actual = self.head
        while actual:
            print(actual.valor, end=" -> ")
            actual = actual.siguiente
        print("None")


# ==============================
# FUNCIONES DEL EXAMEN
# ==============================

def eliminar_duplicados(lista):
    """
    Elimina los elementos duplicados de la lista enlazada
    utilizando un conjunto (set).

    Idea:
    - Recorremos la lista
    - Guardamos los valores ya vistos en un set
    - Si encontramos un valor repetido, eliminamos el nodo
    """
    visitados = set()
    actual = lista.head
    anterior = None

    while actual:
        if actual.valor in visitados:
            # Eliminamos el nodo actual
            anterior.siguiente = actual.siguiente
        else:
            visitados.add(actual.valor)
            anterior = actual
        actual = actual.siguiente


def interseccion(lista, S):
    """
    Retorna una nueva lista enlazada con los elementos
    que están tanto en la lista como en el conjunto S.

    Idea:
    - Recorremos la lista
    - Si el valor está en el set, lo agregamos a la nueva lista
    """
    nueva = Lista()
    actual = lista.head

    while actual:
        if actual.valor in S:
            nueva.insertar_final(actual.valor)
        actual = actual.siguiente

    return nueva


def union(lista, S):
    """
    Retorna una nueva lista enlazada con la unión de:
    - los elementos de la lista
    - los elementos del conjunto S

    Sin duplicados.

    Idea:
    - Usamos un set auxiliar para evitar repetir elementos
    """
    nueva = Lista()
    agregados = set()

    actual = lista.head

    # Agregar elementos de la lista
    while actual:
        if actual.valor not in agregados:
            nueva.insertar_final(actual.valor)
            agregados.add(actual.valor)
        actual = actual.siguiente

    # Agregar elementos del conjunto
    for elemento in S:
        if elemento not in agregados:
            nueva.insertar_final(elemento)
            agregados.add(elemento)

    return nueva


def diferencia(lista, S):
    """
    Retorna una nueva lista con los elementos de la lista
    que NO están en el conjunto S.

    Idea:
    - Filtrar los elementos que no pertenecen al set
    """
    nueva = Lista()
    actual = lista.head

    while actual:
        if actual.valor not in S:
            nueva.insertar_final(actual.valor)
        actual = actual.siguiente

    return nueva


# ==============================
# BONUS (SIN USAR SET)
# ==============================

def eliminar_duplicados_sin_set(lista):
    """
    Elimina duplicados sin usar estructuras auxiliares.

    Idea:
    - Para cada nodo (actual), recorremos el resto de la lista
      con un puntero (runner)
    - Eliminamos cualquier nodo repetido

    Complejidad: O(n^2)
    """
    actual = lista.head

    while actual:
        runner = actual

        while runner.siguiente:
            if runner.siguiente.valor == actual.valor:
                # Eliminamos el duplicado
                runner.siguiente = runner.siguiente.siguiente
            else:
                runner = runner.siguiente

        actual = actual.siguiente


