if __name__ == "__main__":

    lista = Lista()
    lista.insertar_final(1)
    lista.insertar_final(2)
    lista.insertar_final(2)
    lista.insertar_final(3)
    lista.insertar_final(1)

    print("Lista original:")
    lista.imprimir()

    # 1. Eliminar duplicados
    eliminar_duplicados(lista)
    print("\nLista sin duplicados:")
    lista.imprimir()

    # Conjunto de prueba
    S = {2, 3, 4}

    # 2. Intersección
    print("\nIntersección:")
    inter = interseccion(lista, S)
    inter.imprimir()

    # 3. Unión
    print("\nUnión:")
    uni = union(lista, S)
    uni.imprimir()

    # 4. Diferencia
    print("\nDiferencia:")
    dif = diferencia(lista, S)
    dif.imprimir()

    # BONUS
    lista2 = Lista()
    lista2.insertar_final(1)
    lista2.insertar_final(2)
    lista2.insertar_final(2)
    lista2.insertar_final(3)
    lista2.insertar_final(1)

    print("\nLista original (bonus):")
    lista2.imprimir()

    eliminar_duplicados_sin_set(lista2)
    print("Sin duplicados (sin set):")
    lista2.imprimir()
