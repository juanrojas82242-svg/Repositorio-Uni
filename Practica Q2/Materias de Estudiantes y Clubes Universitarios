                PARTE 1: MATERIAS DE ESTUDIANTES
═══════════════════════════════════════════════════════════════════════════════

Usar conjuntos de Python para analizar materias inscritas por estudiantes.

REGLAS:
- Validar que un estudiante no tenga materias repetidas
- Verificar si dos estudiantes comparten materias
- Obtener la unión de materias de un grupo de estudiantes
"""

estudiante_a = ["Matemáticas","Física","Programación","Historia"]
estudiante_b = ["Biología","Física","Programación","Arte"]

# PUNTO 1.1: Validar unicidad de materias
def validar_unicidad(materias):
    """
    Retorna True si no hay materias repetidas
    """
    return len(set(materias)) == len(materias)

# PUNTO 1.2: Verificar si dos estudiantes comparten materias
def tienen_materias_comun(est1, est2):
    """
    Retorna True si hay al menos una materia en común
    """
    return not set(est1).isdisjoint(set(est2))

# PUNTO 1.3: Unión de materias de un grupo
def union_materias(estudiantes):
    """
    Retorna un conjunto con todas las materias inscritas por el grupo
    """
    resultado = set()
    for est in estudiantes:
        resultado |= set(est)
    return resultado


