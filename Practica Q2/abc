if __name__ == "__main__":

    print("Intereses únicos Juan:", intereses_unicos("juan"))
    print("Comunes Juan-Ana:", intereses_comunes("juan", "ana"))
    print("Diferencia Juan-Ana:", diferencia_intereses("juan", "ana"))
    print("Similitud:", similitud("juan", "ana"))
    print("Prefijo 'p':", filtrar_por_prefijo("juan", "p"))

    A = lista_a_conjunto(USUARIOS["juan"])
    B = lista_a_conjunto(USUARIOS["ana"])

    print("\nA:", A)
    print("B:", B)

    print("Intersección:", interseccion(A, B))
    print("Diferencia:", diferencia(A, B))
    print("Tiene todos:", tiene_todos(A, B))
    print("Tiene alguno:", tiene_alguno(A, B))

    print("\n¿Sugerir amistad?:", sugerir_amigos("juan", "ana"))
