                PARTE 1: MATRIZ DE AMIGOS
═══════════════════════════════════════════════════════════════════════════════

Usar conjuntos de Python para validar relaciones de amistad en una matriz.

REGLAS:
- Cada persona debe tener amigos únicos (sin repetidos)
- Validar si dos personas tienen al menos un amigo en común
- Obtener todos los amigos de un grupo de personas
"""

amigos = {
    "ana": ["juan","maria","carlos"],
    "juan": ["ana","sofia","pedro"],
    "maria": ["ana","carlos","sofia"]
}

# PUNTO 1.1: Validar unicidad de amigos
def validar_unicidad(lista_amigos):
    """
    Retorna True si no hay amigos repetidos
    """
    return len(set(lista_amigos)) == len(lista_amigos)

# PUNTO 1.2: Validar si dos personas tienen amigos en común
def tienen_amigos_comun(persona1, persona2):
    """
    Retorna True si hay al menos un amigo en común
    """
    return not set(amigos[persona1]).isdisjoint(set(amigos[persona2]))

# PUNTO 1.3: Obtener todos los amigos de un grupo
def union_amigos(grupo):
    """
    Retorna un conjunto con todos los amigos de las personas en el grupo
    """
    resultado = set()
    for persona in grupo:
        resultado |= set(amigos[persona])
    return resultado


