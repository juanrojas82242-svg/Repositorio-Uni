Usar conjuntos de Python para validar un inventario de productos.

REGLAS:
- No debe haber códigos de producto repetidos
- Todos los códigos deben estar en el rango 100-109
- Validar que dos bodegas no tengan productos en común
"""

CODIGOS_VALIDOS = {100,101,102,103,104,105,106,107,108,109}

bodega_a = [100,101,102,103,104]
bodega_b = [105,106,107,108,109]

# PUNTO 1.1: Validar unicidad en una bodega
def validar_unicidad(bodega):
    """
    Retorna True si no hay códigos repetidos y todos están en CODIGOS_VALIDOS
    """
    return set(bodega).issubset(CODIGOS_VALIDOS) and len(set(bodega)) == len(bodega)

# PUNTO 1.2: Validar que dos bodegas no tengan productos en común
def validar_disjuntas(bodega1, bodega2):
    """
    Retorna True si no hay productos en común entre las dos bodegas
    """
    return set(bodega1).isdisjoint(set(bodega2))


"""
