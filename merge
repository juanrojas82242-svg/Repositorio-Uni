#Merge Sort --> Complejidad O(n log n), espacio O(n), estable
from heapq import merge


def merge_sort(arr,left, middle, right):

    n1 = middle - left + 1
    n2 = right - middle
#divide el arreglo hasta que queden arreglos de una sola posicion
    L = arr[left:middle + 1]
    R = arr[middle + 1:right + 1] #Complejidad espacial O(n), ya que se crean dos arreglos temporales para almacenar los elementos divididos.
    i = j = 0
    k = left
    while i < n1 and j < n2:
        if L[i] <= R[j]:
            arr[k] = L[i]
            i += 1
        else:
            arr[k] = R[j]
            j += 1
        k += 1

    while i < n1:
        arr[k] = L[i]
        i += 1
        k += 1
    
    while j < n2:
        arr[k] = R[j]
        j += 1
        k += 1
    
def mergesort(arr, left, right):
    if left < right:
        middle = (left + right) // 2
        
        mergesort(arr, left, middle)
        mergesort(arr, middle + 1, right)
        merge(arr, left, middle, right) #se va llamando recursivamente a la funcion merge para ir ordenando los elementos a medida que se van dividiendo los arreglos.
    #Complejidad temporal O(n log n), ya que el arreglo se divide en mitades log n veces y cada fusión de dos mitades toma O(n) tiempo.
